# Windows host tools use localhost:5433.
# The Docker Compose app service overrides DATABASE_URL to use postgres:5432.
APP_ENV=local
DATABASE_URL=postgresql://arcforge:arcforge@localhost:5433/arcforge_ai?schema=public
AUTH_SESSION_COOKIE_NAME=arc_forge_session

# Local-only browser URL values. Non-local environments must use HTTPS/WSS.
APP_URL=http://localhost:3000
NEXT_PUBLIC_REALTIME_URL=ws://localhost:3001/ws

# Local placeholders. Use strong unique values outside local development.
INTERNAL_REALTIME_TOKEN_SECRET=arc-forge-local-realtime-secret-change-me
INTERNAL_REALTIME_SERVICE_SECRET=arc-forge-local-realtime-service-secret-change-me
INTERNAL_REALTIME_INTERNAL_URL=http://localhost:3001/internal/broadcast

# Required for Vercel Blob canvas/spec persistence.
BLOB_READ_WRITE_TOKEN=

# Required for Gemini-backed AI design/spec generation.
GOOGLE_AI_API_KEY=
