# Windows host tools use localhost:5433.
# The Docker Compose app service overrides DATABASE_URL to use postgres:5432.
DATABASE_URL=postgresql://arcforge:arcforge@localhost:5433/arcforge_ai?schema=public
AUTH_SESSION_COOKIE_NAME=arc_forge_session

# Required for full collaborative canvas behavior.
LIVEBLOCKS_SECRET_KEY=

# Required for internal realtime room token signing.
INTERNAL_REALTIME_TOKEN_SECRET=

# Required for Vercel Blob canvas/spec persistence.
BLOB_READ_WRITE_TOKEN=

# Required for Gemini-backed AI design/spec generation.
GOOGLE_AI_API_KEY=

APP_URL=http://localhost:3000
