{
  "name": "ghost-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "dev:local": "npm run stack:local:up",
    "stack:local:up": "docker compose -f docker-compose.local.yml up -d --build",
    "stack:local:down": "docker compose -f docker-compose.local.yml down",
    "stack:local:logs": "docker compose -f docker-compose.local.yml logs -f",
    "db:local:up": "docker compose -f docker-compose.local.yml up -d postgres",
    "db:local:down": "docker compose -f docker-compose.local.yml stop postgres",
    "db:local:logs": "docker compose -f docker-compose.local.yml logs -f postgres",
    "app:local:logs": "docker compose -f docker-compose.local.yml logs -f app",
    "worker:local:logs": "docker compose -f docker-compose.local.yml logs -f worker",
    "realtime:local:logs": "docker compose -f docker-compose.local.yml logs -f realtime",
    "ai:worker": "tsx scripts/ai-worker.ts",
    "realtime:server": "tsx scripts/realtime-server.ts",
    "test:transport-security": "tsx scripts/transport-security-smoke.ts",
    "test:storage": "tsx scripts/storage-smoke.ts",
    "db:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.65",
    "@base-ui/react": "^1.4.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/blob": "^2.3.3",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.170",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
